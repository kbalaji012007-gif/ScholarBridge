# ===================================
# ScholarBridge – Environment Config
# ===================================
# Copy this to .env and fill in values

# App
APP_NAME=ScholarBridge
ENVIRONMENT=development
DEBUG=false

# Security – CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# Database
# SQLite (development):
DATABASE_URL=sqlite:///./scholarbridge.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/scholarbridge

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Email (optional, for notifications)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@scholarbridge.com

# Firebase Storage (optional)
FIREBASE_CREDENTIALS_PATH=
FIREBASE_STORAGE_BUCKET=
