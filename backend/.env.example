# ─── CareerBridge AI — Backend Environment Configuration ───────────────
# Copy this file to .env and fill in your values

# Application
APP_NAME="CareerBridge AI"
APP_VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=production

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-key-min-32-chars-long-change-this-now
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# For local development:
DATABASE_URL=sqlite:///./careerbridge.db
# For production (Supabase / Render PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/careerbridge

# CORS — Your Vercel frontend URL
FRONTEND_URL=https://careerbridge-ai.vercel.app

# File Uploads
UPLOAD_DIR=uploads
RESUME_UPLOAD_DIR=uploads/resumes
MAX_FILE_SIZE_MB=5
MAX_RESUME_SIZE_MB=10

# ─── AI Configuration ────────────────────────────────────────────────────
# Provider options: "gemini" | "openai" | "mock"
# Use "mock" for development (no API key needed)
AI_PROVIDER=mock

# Google Gemini AI (recommended)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=

AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# ─── Email (optional) ────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@careerbridge.ai
EMAILS_FROM_NAME=CareerBridge AI
